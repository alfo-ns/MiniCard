{
  "name": "minicard",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "cd client && npm run build && cd ../server && npm run build",
    "generate-hash": "node --input-type=module --eval \"import b from 'bcryptjs'; const pw=process.argv[1]; b.hash(pw,10).then(h=>{console.log(h);process.exit()})\" --"
  }
}
